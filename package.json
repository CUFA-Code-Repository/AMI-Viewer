{
  "name": "ami-viewer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "AMIv2 Flight Data Viewer — offline web app for viewing AMIv2 flight logs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:single": "vite build && vite-plugin-singlefile-inline || vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "gen:sample": "node scripts/gen-sample-session.mjs sample/0007 && node scripts/gen-sample-session.mjs sample/0008 --truncate && node scripts/gen-sample-session.mjs sample/0009 --wrap",
    "test": "esbuild scripts/test-parse.mjs --bundle --platform=node --format=esm --outfile=.test-bundle.mjs --log-level=warning && node .test-bundle.mjs"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tsconfig/svelte": "^5.0.4",
    "@types/papaparse": "^5.5.2",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tslib": "^2.7.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-singlefile": "^2.0.3"
  },
  "dependencies": {
    "papaparse": "^5.4.1"
  }
}
